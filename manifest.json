{
  "manifest_version": 3,
  "name": "やさしい1分",
  "description": "60秒で落ち着く小さな休憩と穏やかな返信アシスト",
  "version": "0.1.0",
  "action": { "default_popup": "popup.html", "default_title": "やさしい1分" },
  "background": { "service_worker": "background.js" },
  "permissions": ["storage", "contextMenus", "activeTab", "scripting", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}

